<%= form_with(model: [@list, item], local: true) do |form| %>
  <% if item.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(item.errors.count, "erro") %> impediram o item de ser salvo:</h2>
      <ul>
        <% item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nome do Item" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.submit "Salvar" %>
  </div>
<% end %>
