<p style="color: green"><%= notice %></p>

<% content_for :title, "Items" %>

<h1>Items</h1>

<div id="items">
  <% if @items.any? %>
    <% @items.each do |item| %>
      <%= render item %>  <!-- Renderiza o item -->
      <p>
        <%= link_to "Show this item", list_item_path(@list, item) %> <!-- Corrigido para usar list_item_path -->
      </p>
    <% end %>
  <% else %>
    <p>No items found.</p>
  <% end %>
</div>

<%= link_to "New item", new_item_path %>
